# AI Agent API - 开发环境
# 开发环境使用 /agent-api 前缀，由 Vite 开发服务器代理到真实后端
VITE_APP_AI_URL=/agent-screen/screen
VITE_APP_AI_TOKEN=

# 普通业务 API
VITE_APP_BASE_API=
VITE_APP_COMMON_API=/bus

# 无人机 facade 直连鉴权（可选；若仅走 BFF 且服务端已带 inner-token 可不填）
VITE_APP_UAV_INNER_TOKEN=https://data.nxzhnyyjy.com:9082

# 各独立系统 baseURL（开发环境走 Vite proxy，留空即可）
VITE_APP_RESOURCE_API=
VITE_APP_ADP_API=
VITE_APP_AISCREEN_API=
VITE_APP_IOTZHIBAO_API=
VITE_APP_IOTSHANGQING_API=

# 虫情原始接口鉴权。ADP token 为空时会沿用当前登录 token；Resource token 默认兼容墒情直连 token。
VITE_APP_CHONGQING_ADP_TOKEN=
VITE_APP_CHONGQING_PLANT_PROTECT_TOKEN=7a194e7f94454149bd21108085dd8040
VITE_APP_CHONGQING_RESOURCE_TOKEN=
VITE_APP_CHONGQING_REQUEST_TIMEOUT=180000

