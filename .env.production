# AI Agent API - 生产环境
VITE_APP_AI_URL=https://test.nxzhnyyjy.com:9082/agent-screen/screen
VITE_APP_AI_TOKEN=

# 普通业务 API（/agent-screen、/bus 等默认走此 baseURL）
VITE_APP_BASE_API=https://test.nxzhnyyjy.com:9082/

# common 接口（/common/ 请求切换至此）
VITE_APP_COMMON_API=https://test.nxzhnyyjy.com:9082/agent-screen/screen/bus/

# 墒情资源接口（/resource/ 开头请求，路径保留 /resource）
VITE_APP_RESOURCE_API=https://jsiot.nxzhnyyjy.com:9082/

# 无人机 facade 直连鉴权（可选；若仅走 BFF 且服务端已带 inner-token 可不填）
VITE_APP_UAV_INNER_TOKEN=https://data.nxzhnyyjy.com:9082

# 虫情 ADP 接口（/adp/ 开头请求，路径保留 /adp）
VITE_APP_ADP_API=https://jsiot.jssny.com.cn/

# AI 大屏接口（/aiScreen/ 开头请求，路径中的 /aiScreen 前缀会被自动去除）
VITE_APP_AISCREEN_API=https://pukoushanbei.nxzhnyyjy.com:9082/production/aiScreen

# 植保站接口（/iotzhibaozhan/ 开头请求，前缀会被自动去除）
VITE_APP_IOTZHIBAO_API=https://test.nxzhnyyjy.com:9082/agent-screen/iotzhibaozhan/

# 墒情 IoT 接口（/iotshangqing/ 开头请求，前缀会被自动去除）
VITE_APP_IOTSHANGQING_API=https://test.nxzhnyyjy.com:9082/agent-screen/iotshangqing/

# 虫情原始接口鉴权。生产建议由部署环境注入，不在仓库内写死 ADP token。
VITE_APP_CHONGQING_ADP_TOKEN=
VITE_APP_CHONGQING_PLANT_PROTECT_TOKEN=
VITE_APP_CHONGQING_RESOURCE_TOKEN=
VITE_APP_CHONGQING_REQUEST_TIMEOUT=180000

# Vite 开发服务器代理目标地址（生产环境通常由 nginx 处理，此处保留配置一致性）
VITE_PROXY_AGENT_API_TARGET=https://test.nxzhnyyjy.com:9082/agent-screen/screen/
VITE_PROXY_BUS_TARGET=https://test.nxzhnyyjy.com:9082/agent-screen/screen/bus/
VITE_PROXY_IOTZHIBAO_TARGET=https://test.nxzhnyyjy.com:9082/agent-screen/iotzhibaozhan/
VITE_PROXY_IOTSHANGQING_TARGET=https://test.nxzhnyyjy.com:9082/agent-screen/iotshangqing/
VITE_PROXY_AISCREEN_TARGET=https://pukoushanbei.nxzhnyyjy.com:9082/production/aiScreen
VITE_PROXY_ADP_TARGET=https://jsiot.jssny.com.cn/adp/
VITE_PROXY_RESOURCE_TARGET=https://jsiot.nxzhnyyjy.com:9082/resource/
VITE_PROXY_AGENT_SCREEN_TARGET=https://test.nxzhnyyjy.com:9082/
